# Copy to .env before running docker compose.
POSTGRES_PASSWORD=change-me-strong-db-password

# Generate each with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-random-64-hex
JWT_REFRESH_SECRET=change-me-different-random-64-hex
COOKIE_SECRET=change-me-cookie-secret

# Public origin of the web app (used for CORS)
CORS_ORIGINS=http://localhost:3000
