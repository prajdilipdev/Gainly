# PostgreSQL connection string
DATABASE_URL=postgresql://spt:spt_password@localhost:5432/stock_portfolio?schema=public

# JWT secrets — MUST be long random strings in production (>= 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters
JWT_REFRESH_SECRET=change-me-to-a-different-random-string-32-chars

# Redis (optional in dev — falls back to in-memory cache when unset)
REDIS_URL=redis://localhost:6379

# HTTP
PORT=4000
CORS_ORIGINS=http://localhost:3000
COOKIE_SECRET=change-me-cookie-secret
